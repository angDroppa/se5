// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["s5"]
}

model Role {
  role  String @id
  users User[]

  @@schema("s5")
}

model User {
  id        Int    @id @default(autoincrement())
  firstName String
  lastName  String
  email     String @unique
  password  String

  role     Role   @relation(fields: [roleName], references: [role])
  roleName String @default("USER")

  refreshTokens RefreshToken[]

  refoundRequestsCreated   RefoundReq[] @relation("UserRefounds")
  refoundRequestsEvaluated RefoundReq[] @relation("UserEvaluations")

  @@schema("s5")
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@schema("s5")
}

model CategoryReq {
  id String @id

  refound RefoundReq[]

  @@schema("s5")
}

model StateReq {
  id String @id

  refound RefoundReq[]

  @@schema("s5")
}

model RefoundReq {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())

  expenseDate DateTime

  category    String
  categoryReq CategoryReq @relation(fields: [category], references: [id], onDelete: Cascade)

  import      Decimal @db.Decimal(10, 2)
  description String
  refDocument String?

  state    String   @default("ATTESA")
  stateReq StateReq @relation(fields: [state], references: [id], onDelete: Cascade)

  userId Int
  user   User @relation("UserRefounds", fields: [userId], references: [id], onDelete: Cascade)

  evaluatorId Int?
  evaluator   User? @relation("UserEvaluations", fields: [evaluatorId], references: [id], onDelete: SetNull)

  evaluationDate DateTime?

  denyDescription String?

  payDate DateTime?

  @@schema("s5")
}
